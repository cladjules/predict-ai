# Your receiving wallet address (EVM-compatible address)
WALLET_RECIPIENT_ADDRESS=0xYourWalletAddressHere
WALLET_PRIVATE_KEY=0x

# IF running simulation mode (no real blockchain interactions, for testing purposes)
SIMULATE=true

# Network configuration
# Testnet: eip155:84532 (Base Sepolia)
# Mainnet: eip155:8453 (Base)
NETWORK=eip155:84532
NETWORK_IS_TESTNET=true

# USDC On Base Sepolia
PAYMENT_TOKEN=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Facilitator URL
# Testnet: https://www.x402.org/facilitator
# Mainnet: Configure with CDP credentials (see README)
FACILITATOR_URL=https://www.x402.org/facilitator

# Paywall Configuration
APP_NAME=X402 Payment Server

# Optional: For mainnet CDP facilitator
# CDP_API_KEY_ID=your-api-key-id
# CDP_API_KEY_SECRET=your-api-key-secret

# Server Configuration
PORT=4021
NODE_ENV=development

# CRE HTTP Trigger
CRE_TRIGGER_URL=https://01.gateway.zone-a.cre.chain.link
CRE_WORKFLOW_ID=a1b2c3

# Database connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# API Key for CRE workflows to access backend
API_KEY=your-secure-api-key-here